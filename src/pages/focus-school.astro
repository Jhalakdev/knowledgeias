    icon: "atom",
    summary: "Space, defence, nanotech, IT, nuclear, biotech, IPR.",
    lectures: [
      "Basic Physics Related to Space Technology",
      "Recent Space Launches & Future Plans",
      "Defence Technology & Its Application",
      "Nanotechnology & Its Application",
      "Information Technology & Its Applications",
      "Nuclear Technology & Its Applications",
      "Basics of Cell Biology",
      "Biotechnology & Its Applications",
      "Intellectual Property Rights",
    ],
  },
  {
    subject: "International Relations",
    icon: "globe",
    summary: "World order, diplomacy, India's neighbours, global groups.",
    lectures: [
      "World Order (Part 1)",
      "World Order (Part 2)",
      "Key Theories of International Relations (Part 1)",
      "Key Theories of International Relations (Part 2)",
      "Key Determinants of India's Foreign Policy (Part 1)",
      "Key Determinants of India's Foreign Policy (Part 2)",
      "India's Key Foreign Policy Doctrines (Part 1)",
      "India's Key Foreign Policy Doctrines (Part 2)",
      "Decoding Multiple Layers of Diplomacy (Part 1)",
      "Decoding Multiple Layers of Diplomacy (Part 2)",
      "India's Key Issues With Neighbours (Part 1)",
      "India's Key Issues With Neighbours (Part 2)",
      "India-USA Relations (Part 1)",
      "India-USA Relations (Part 2)",
      "India-Russia Relations",
      "India-China Relations",
      "India-Europe Relations",
      "India-South Africa Relations",
      "Key Global Groups",
      "Key Global Institutions of Global Governance",
      "Key Global Issues",
      "India's Ambition as Global Superpower",
      "Key Concepts of International Relations",
    ],
  },
  {
    subject: "Post-Independence History",
    icon: "history",
    summary: "Prime Ministers, states, language, Green Revolution, Emergency.",
    lectures: [
      "Prime Ministers & Nation Building (Part 1)",
      "Prime Ministers & Nation Building (Part 2)",
      "Formation of States & Regional Aspirations",
      "Language Politics & Identity",
      "Congress System & Political Evolution",
      "Green Revolution & Agrarian Change",
      "Land Reforms (Power, Inequality & State)",
      "JP Movement & Emergency",
      "Regionalism in India",
      "1991 Economic Crisis & Reforms",
      "Dilemmas & Choices Behind India's Foreign Policy",
      "Constitutional & Institutional Evolution",
    ],
  },
  {
    subject: "Environment & Ecology",
    icon: "leaf",
    summary: "Ecology, biodiversity, pollution, climate change, laws.",
    lectures: [
