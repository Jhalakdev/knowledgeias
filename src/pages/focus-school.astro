    summary: "Earth, world geography, Indian geography, drainage, soil.",
    lectures: [
      "Universe & Solar System",
      "Earth Geometry",
      "Geological Time Scale",
      "World Geography (Part 1)",
      "World Geography (Part 2)",
      "Indian Geography",
