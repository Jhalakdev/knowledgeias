---
import Layout from "../layouts/Layout.astro";
---
<Layout title="Contact Us — Knowledge IAS Academy">
  <section class="relative max-w-7xl mx-auto px-5 sm:px-8 pt-16 lg:pt-24 pb-10">
    <div class="absolute top-0 right-0 w-[40%] h-full bg-[radial-gradient(ellipse_at_top_right,rgba(245,166,35,0.14),transparent_60%)] -z-10"></div>

    <div class="grid lg:grid-cols-12 gap-10 lg:gap-16 items-start">
      <div class="lg:col-span-5" data-reveal>
        <span class="chip"><span class="dot"></span>Contact Us</span>
        <h1 class="mt-6 text-4xl sm:text-5xl lg:text-6xl leading-[1.05]">
          Let's plan your <span class="gold-underline-animated">UPSC journey</span> together.
        </h1>
        <p class="mt-6 text-lg text-[var(--color-muted)] leading-relaxed">
          Tell us a little about yourself and we'll get back within one working day — or reach us directly on WhatsApp, email or any of our channels below. We run a <strong>100% online</strong> academy, so you can join from anywhere in India.
        </p>

        <div class="mt-10 space-y-6">
          <div class="flex gap-4">
            <div class="h-10 w-10 rounded-full bg-[var(--color-gold-soft)] flex items-center justify-center flex-none">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#0b0b0b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"></path></svg>
            </div>
            <div>
              <p class="text-xs uppercase tracking-[0.2em] text-[var(--color-gold-deep)] font-semibold">Call / WhatsApp</p>
              <p class="mt-1 text-[var(--color-ink-soft)] text-lg">
                <a href="tel:+918329544987" class="hover:text-[var(--color-gold-deep)] font-medium">+91 83295 44987</a>
              </p>
              <p class="mt-0.5 text-xs text-[var(--color-muted)]">Mon – Sat · 9:00 am to 9:00 pm</p>
            </div>
          </div>

          <div class="flex gap-4">
            <div class="h-10 w-10 rounded-full bg-[var(--color-gold-soft)] flex items-center justify-center flex-none">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#0b0b0b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
            </div>
            <div>
              <p class="text-xs uppercase tracking-[0.2em] text-[var(--color-gold-deep)] font-semibold">Email</p>
              <p class="mt-1 text-[var(--color-ink-soft)] text-lg">
                <a href="mailto:knowledge4ias@gmail.com" class="hover:text-[var(--color-gold-deep)] font-medium">knowledge4ias@gmail.com</a>
              </p>
            </div>
          </div>

          <div class="flex gap-4">
            <div class="h-10 w-10 rounded-full bg-[var(--color-gold-soft)] flex items-center justify-center flex-none">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#0b0b0b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
            </div>
            <div>
              <p class="text-xs uppercase tracking-[0.2em] text-[var(--color-gold-deep)] font-semibold">Coaching Mode</p>
              <p class="mt-1 text-[var(--color-ink-soft)] text-lg font-medium">100% Online · PAN India</p>
              <p class="mt-0.5 text-xs text-[var(--color-muted)]">Live sessions + recordings + mentor access</p>
            </div>
          </div>

          <div class="pt-4 border-t border-[var(--color-line)]">
            <p class="text-xs uppercase tracking-[0.2em] text-[var(--color-gold-deep)] font-semibold">Follow Knowledge IAS</p>
            <div class="mt-3 flex flex-wrap gap-2">
              <a href="https://www.instagram.com/knowledge_ias_academy" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-sm px-3.5 py-2 rounded-full border border-[var(--color-line)] hover:bg-[var(--color-gold-soft)] transition-colors">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M7 3h10a4 4 0 0 1 4 4v10a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4V7a4 4 0 0 1 4-4zm5 5a4 4 0 1 0 0 8 4 4 0 0 0 0-8zm5-1.5a1 1 0 1 0 0 2 1 1 0 0 0 0-2z"/></svg>
                Instagram
              </a>
              <a href="https://youtube.com/@knowledgeiasacademy" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-sm px-3.5 py-2 rounded-full border border-[var(--color-line)] hover:bg-[var(--color-gold-soft)] transition-colors">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M22 12s0-3.5-.5-5.2A2.8 2.8 0 0 0 19.5 5C17.7 4.5 12 4.5 12 4.5s-5.7 0-7.5.5A2.8 2.8 0 0 0 2.5 6.8C2 8.5 2 12 2 12s0 3.5.5 5.2A2.8 2.8 0 0 0 4.5 19c1.8.5 7.5.5 7.5.5s5.7 0 7.5-.5a2.8 2.8 0 0 0 2-1.8c.5-1.7.5-5.2.5-5.2zM10 15.3V8.7l5.5 3.3L10 15.3z"/></svg>
                YouTube
              </a>
              <a href="https://www.facebook.com/share/1adu4VRkK6/?mibextid=wwXIfr" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-sm px-3.5 py-2 rounded-full border border-[var(--color-line)] hover:bg-[var(--color-gold-soft)] transition-colors">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M22 12a10 10 0 1 0-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.51 1.49-3.9 3.78-3.9 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56V12h2.77l-.44 2.89h-2.33v6.99A10 10 0 0 0 22 12z"/></svg>
                Facebook
              </a>
            </div>
          </div>
        </div>
      </div>

      <div class="lg:col-span-7" data-reveal data-reveal-delay="2">
        <form id="contact-form" class="card card-gold-corner p-7 sm:p-10 relative" novalidate>
          <div class="flex items-center justify-between">
            <h2 class="font-serif text-2xl">Send us a message</h2>
            <span class="text-xs text-[var(--color-muted)]">Takes ~30 seconds</span>
          </div>
          <div class="hairline my-6"></div>

          <div class="grid sm:grid-cols-2 gap-5">
            <label class="block">
              <span class="block text-xs uppercase tracking-[0.15em] font-semibold text-[var(--color-ink-soft)]">Full Name *</span>
              <input type="text" name="name" required class="mt-2 w-full bg-transparent border-b border-[var(--color-line)] focus:border-[var(--color-gold-deep)] py-2 outline-none transition-colors text-[var(--color-ink)]" placeholder="Your name" />
            </label>

            <label class="block">
              <span class="block text-xs uppercase tracking-[0.15em] font-semibold text-[var(--color-ink-soft)]">Phone *</span>
              <input type="tel" name="phone" required inputmode="tel" pattern="[0-9+\- ]{7,}" class="mt-2 w-full bg-transparent border-b border-[var(--color-line)] focus:border-[var(--color-gold-deep)] py-2 outline-none transition-colors" placeholder="+91" />
            </label>

            <label class="block sm:col-span-2">
              <span class="block text-xs uppercase tracking-[0.15em] font-semibold text-[var(--color-ink-soft)]">Email *</span>
              <input type="email" name="email" required class="mt-2 w-full bg-transparent border-b border-[var(--color-line)] focus:border-[var(--color-gold-deep)] py-2 outline-none transition-colors" placeholder="you@example.com" />
            </label>

            <label class="block">
              <span class="block text-xs uppercase tracking-[0.15em] font-semibold text-[var(--color-ink-soft)]">I am a *</span>
              <select name="role" required class="mt-2 w-full bg-transparent border-b border-[var(--color-line)] focus:border-[var(--color-gold-deep)] py-2 outline-none transition-colors">
                <option value="">Select one</option>
                <option>School Student</option>
                <option>College Student</option>
                <option>Graduate / Working Professional</option>
                <option>Parent / Guardian</option>
                <option>Other</option>
              </select>
            </label>

            <label class="block">
              <span class="block text-xs uppercase tracking-[0.15em] font-semibold text-[var(--color-ink-soft)]">Interested In *</span>
              <select name="programme" required class="mt-2 w-full bg-transparent border-b border-[var(--color-line)] focus:border-[var(--color-gold-deep)] py-2 outline-none transition-colors">
                <option value="">Select one</option>
                <option>FOCUS SCHOOL (flagship)</option>
                <option>UPSC Prelims Programme</option>
                <option>UPSC Mains Programme</option>
                <option>Counselling Session</option>
                <option>General Enquiry</option>
              </select>
            </label>

            <label class="block sm:col-span-2">
              <span class="block text-xs uppercase tracking-[0.15em] font-semibold text-[var(--color-ink-soft)]">Your Message</span>
              <textarea name="message" rows="4" class="mt-2 w-full bg-transparent border-b border-[var(--color-line)] focus:border-[var(--color-gold-deep)] py-2 outline-none transition-colors resize-none" placeholder="Tell us a bit about your goals, class / year, and any questions you have."></textarea>
            </label>
          </div>

          <input type="text" name="company" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />

          <div class="mt-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <p class="text-xs text-[var(--color-muted)]">By submitting, you agree to be contacted by our counselling team.</p>
            <button type="submit" id="submit-btn" class="btn-primary">
              <span id="submit-label">Send Message</span>
              <svg id="submit-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
            </button>
          </div>

          <div id="form-status" class="mt-6 hidden" role="status" aria-live="polite"></div>
        </form>
      </div>
    </div>
  </section>
</Layout>

<script is:inline>
  const form = document.getElementById("contact-form");
  const status = document.getElementById("form-status");
  const btn = document.getElementById("submit-btn");
  const label = document.getElementById("submit-label");

  function show(type, msg) {
    status.className = "mt-6 rounded-xl p-4 text-sm " + (
      type === "ok"
        ? "bg-[var(--color-gold-soft)] text-[var(--color-ink)]"
        : "bg-red-50 text-red-700 border border-red-200"
    );
    status.textContent = msg;
  }

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    status.classList.remove("hidden");
    status.className = "mt-6 text-sm text-[var(--color-muted)]";
    status.textContent = "Sending…";

    const data = new FormData(form);
    if (data.get("company")) return;

    const payload = Object.fromEntries(data.entries());
    delete payload.company;

    btn.disabled = true;
    label.textContent = "Sending…";

    try {
      const res = await fetch("/api/contact", {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify(payload),
      });
      const body = await res.json().catch(() => ({}));
      if (!res.ok || body.ok === false) {
        throw new Error(body.error || "Request failed");
      }
      form.reset();
      show("ok", "Thank you — your message has been received. Our counselling team will reach out within one working day.");
    } catch (err) {
      show("err", "Something went wrong. Please call us at +91 83295 44987 or email knowledge4ias@gmail.com.");
    } finally {
      btn.disabled = false;
      label.textContent = "Send Message";
    }
  });
</script>
