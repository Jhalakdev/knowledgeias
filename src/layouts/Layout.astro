---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Knowledge IAS Academy — Premier UPSC Coaching in India",
  description = "Knowledge IAS Academy prepares aspirants for the UPSC Civil Services Examination. Home to FOCUS SCHOOL — our flagship programme for school students.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/logo.png" />
    <link rel="icon" type="image/png" href="/logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&display=swap"
    />
  </head>
  <body>
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:top-3 focus:left-3 focus:z-50 bg-[var(--color-ink)] text-[var(--color-cream)] px-3 py-2 rounded-md">Skip to content</a>
    <Navbar />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <!-- Floating WhatsApp Widget -->
    <div id="wa-widget" class="fixed bottom-5 right-4 sm:right-6 z-50 flex flex-col items-end gap-3 pointer-events-none">
      <div
        id="wa-bubble"
        class="opacity-0 translate-y-2 transition-all duration-300 ease-out pointer-events-auto bg-white rounded-2xl shadow-[0_12px_40px_-12px_rgba(11,11,11,0.25)] border border-[var(--color-line)] px-4 py-3 max-w-[16rem] flex items-start gap-3"
      >
        <div class="h-9 w-9 rounded-full bg-[#25D366] flex items-center justify-center flex-none">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="white" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347M12.05 21.785h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0 0 20.464 3.488"/>
          </svg>
        </div>
        <div class="flex-1 min-w-0">
          <p class="text-[10px] uppercase tracking-[0.18em] text-[var(--color-gold-deep)] font-semibold">Knowledge IAS</p>
          <p class="text-sm text-[var(--color-ink)] mt-0.5 leading-snug">Hi! How may I help you?</p>
          <a
            href="https://wa.me/918329544987?text=Hi%21%20I%27d%20like%20to%20know%20more%20about%20Knowledge%20IAS%20Academy%20and%20the%20FOCUS%20SCHOOL%20Programme."
            target="_blank"
            rel="noopener"
            class="inline-block mt-2 text-xs font-semibold text-[#1da851] hover:underline"
          >Chat on WhatsApp →</a>
        </div>
        <button id="wa-close" type="button" aria-label="Dismiss WhatsApp prompt" class="text-[var(--color-muted)] hover:text-[var(--color-ink)] text-xl leading-none -mt-0.5 -mr-1 px-1">×</button>
      </div>

      <a
        id="wa-button"
        href="https://wa.me/918329544987?text=Hi%21%20I%27d%20like%20to%20know%20more%20about%20Knowledge%20IAS%20Academy%20and%20the%20FOCUS%20SCHOOL%20Programme."
        target="_blank"
        rel="noopener"
        aria-label="Chat with us on WhatsApp"
        class="pointer-events-auto h-14 w-14 rounded-full bg-[#25D366] hover:bg-[#1da851] shadow-[0_10px_30px_-8px_rgba(37,211,102,0.55)] flex items-center justify-center text-white transition-transform hover:scale-105 active:scale-95"
      >
        <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="wa-icon-shake">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347M12.05 21.785h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0 0 20.464 3.488"/>
        </svg>
      </a>
    </div>

    <script is:inline>
      (() => {
        if (typeof IntersectionObserver === "undefined") {
          document.querySelectorAll("[data-reveal]").forEach((el) => el.classList.add("is-visible"));
          return;
        }
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                io.unobserve(entry.target);
              }
            }
          },
          { rootMargin: "0px 0px -8% 0px", threshold: 0.08 }
        );
        document.querySelectorAll("[data-reveal]").forEach((el) => io.observe(el));

        // Subtle scroll shadow on navbar
        const header = document.querySelector("header[data-navbar]");
        if (header) {
          const onScroll = () => {
            if (window.scrollY > 8) header.setAttribute("data-scrolled", "true");
            else header.removeAttribute("data-scrolled");
          };
          onScroll();
          window.addEventListener("scroll", onScroll, { passive: true });
        }

        // WhatsApp prompt bubble — auto-show after a short delay, re-show periodically
        const bubble = document.getElementById("wa-bubble");
        const closeBtn = document.getElementById("wa-close");
        const button = document.getElementById("wa-button");
        if (bubble && closeBtn && button) {
          function showBubble() {
            bubble.classList.remove("opacity-0", "translate-y-2");
            bubble.classList.add("opacity-100", "translate-y-0");
          }
          function hideBubble() {
            bubble.classList.add("opacity-0", "translate-y-2");
            bubble.classList.remove("opacity-100", "translate-y-0");
          }
          // Show initially after 2s, then re-show every 30s
          setTimeout(showBubble, 2000);
          setInterval(showBubble, 30000);
          closeBtn.addEventListener("click", hideBubble);
          button.addEventListener("click", hideBubble);
        }
      })();
    </script>
  </body>
</html>
