---
const year = new Date().getFullYear();

const socials = [
  {
    href: "https://www.instagram.com/knowledge_ias_academy",
    label: "Instagram",
    path: "M7 3h10a4 4 0 0 1 4 4v10a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4V7a4 4 0 0 1 4-4zm5 5a4 4 0 1 0 0 8 4 4 0 0 0 0-8zm5-1.5a1 1 0 1 0 0 2 1 1 0 0 0 0-2z",
  },
  {
    href: "https://youtube.com/@knowledgeiasacademy",
    label: "YouTube",
    path: "M22 12s0-3.5-.5-5.2A2.8 2.8 0 0 0 19.5 5C17.7 4.5 12 4.5 12 4.5s-5.7 0-7.5.5A2.8 2.8 0 0 0 2.5 6.8C2 8.5 2 12 2 12s0 3.5.5 5.2A2.8 2.8 0 0 0 4.5 19c1.8.5 7.5.5 7.5.5s5.7 0 7.5-.5a2.8 2.8 0 0 0 2-1.8c.5-1.7.5-5.2.5-5.2zM10 15.3V8.7l5.5 3.3L10 15.3z",
  },
  {
    href: "https://www.facebook.com/share/1adu4VRkK6/?mibextid=wwXIfr",
    label: "Facebook",
    path: "M22 12a10 10 0 1 0-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.51 1.49-3.9 3.78-3.9 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56V12h2.77l-.44 2.89h-2.33v6.99A10 10 0 0 0 22 12z",
  },
];
---
<footer class="mt-28 bg-[var(--color-ink)] text-[var(--color-cream)] relative overflow-hidden">
  <div class="absolute inset-0 opacity-[0.05]" style="background-image: radial-gradient(circle at 15% 20%, #f5a623 0, transparent 45%), radial-gradient(circle at 85% 80%, #f5a623 0, transparent 45%);"></div>
  <div class="absolute inset-0 jali-pattern opacity-30"></div>

  <!-- Newsletter strip -->
  <div class="relative border-b border-white/10">
    <div class="max-w-7xl mx-auto px-5 sm:px-8 py-10 grid md:grid-cols-[1.5fr_1fr] gap-8 items-center">
      <div>
        <p class="text-xs uppercase tracking-[0.22em] text-[var(--color-gold)] font-semibold">Stay connected</p>
        <h3 class="mt-2 font-serif text-2xl sm:text-3xl text-[var(--color-cream)]">Get notified about new batches &amp; events.</h3>
      </div>
      <form id="newsletter-form" class="relative">
        <div class="flex gap-2">
          <input
            type="email"
            name="email"
            required
            placeholder="you@example.com"
            class="flex-1 bg-white/5 border border-white/15 focus:border-[var(--color-gold)] rounded-full px-5 py-3 outline-none text-sm text-[var(--color-cream)] placeholder:text-white/40 transition-colors"
            aria-label="Email address"
          />
          <button type="submit" id="newsletter-btn" class="btn-primary !bg-[var(--color-gold)] !text-[var(--color-ink)] hover:!bg-[var(--color-cream)] !py-3 !px-5 text-sm">
            <span id="newsletter-btn-label">Subscribe</span>
          </button>
        </div>
        <p id="newsletter-msg" class="mt-2 text-xs hidden" role="status" aria-live="polite"></p>
      </form>

      <script is:inline>
        (() => {
          const form = document.getElementById("newsletter-form");
          const btn = document.getElementById("newsletter-btn");
          const lbl = document.getElementById("newsletter-btn-label");
          const msg = document.getElementById("newsletter-msg");
          if (!form) return;
          form.addEventListener("submit", async (e) => {
            e.preventDefault();
            const input = form.querySelector("input[name='email']");
            const email = (input && "value" in input ? input.value : "").trim();
            if (!email) return;
            msg.classList.remove("hidden");
            msg.className = "mt-2 text-xs text-white/60";
            msg.textContent = "Subscribing…";
            btn.disabled = true;
            lbl.textContent = "…";
            try {
              const res = await fetch("/api/newsletter", {
                method: "POST",
                headers: { "content-type": "application/json" },
                body: JSON.stringify({ email }),
              });
              const body = await res.json().catch(() => ({}));
              if (!res.ok || body.ok === false) throw new Error(body.error || "Failed");
              msg.className = "mt-2 text-xs text-[var(--color-gold)]";
              msg.textContent = body.alreadyExists
                ? "You're already on our list. Thanks again!"
                : "Thank you — you'll hear from us soon.";
              input.value = "";
            } catch (err) {
              msg.className = "mt-2 text-xs text-red-300";
              msg.textContent = "Something went wrong. Please try again.";
            } finally {
              btn.disabled = false;
              lbl.textContent = "Subscribe";
            }
          });
        })();
      </script>
    </div>
  </div>

  <div class="relative max-w-7xl mx-auto px-5 sm:px-8 py-16 grid gap-12 md:grid-cols-4">
    <div class="md:col-span-2 max-w-md">
      <div class="flex items-center gap-3">
        <img src="/logo.png" alt="Knowledge IAS" class="h-20 w-auto object-contain" style="filter: brightness(0) invert(1);" />
      </div>
      <p class="mt-4 text-sm leading-relaxed text-[rgba(250,246,236,0.72)]">
        A premier <span class="text-[var(--color-gold)]">online academy</span> guiding aspirants of the UPSC Civil Services Examination. Home to <span class="text-[var(--color-gold)]">FOCUS&nbsp;SCHOOL</span> — our flagship programme for school students aspiring to serve the nation.
      </p>

      <div class="mt-6 flex gap-3">
        {socials.map((s) => (
          <a
            href={s.href}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={s.label}
            class="h-10 w-10 rounded-full border border-white/15 text-[rgba(250,246,236,0.8)] hover:text-[var(--color-ink)] hover:bg-[var(--color-gold)] hover:border-[var(--color-gold)] flex items-center justify-center transition-colors"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d={s.path}/></svg>
          </a>
        ))}
      </div>

      <a
        href="https://play.google.com/store/apps/details?id=com.wficwu.qzsmcs"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Get our Android app on Google Play"
        class="mt-6 inline-flex items-center gap-3 bg-white/[0.04] hover:bg-[var(--color-gold)] hover:text-[var(--color-ink)] border border-white/15 hover:border-[var(--color-gold)] rounded-xl px-4 py-2.5 transition-colors"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 01-.61-.92V2.734a1 1 0 01.609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-3.198l2.807 1.626a1 1 0 010 1.73l-2.808 1.626L15.495 12l2.203-2.491zM5.864 2.658L16.802 8.99l-2.302 2.302-8.636-8.634z"/>
        </svg>
        <span class="leading-tight text-left">
          <span class="block text-[9px] uppercase tracking-[0.22em] text-[rgba(250,246,236,0.6)] group-hover:text-[var(--color-ink)]">Get it on</span>
          <span class="block text-sm font-semibold">Google Play</span>
        </span>
      </a>
    </div>

    <div>
      <h4 class="text-sm tracking-[0.22em] uppercase text-[var(--color-gold)] font-sans font-semibold">Explore</h4>
      <ul class="mt-5 space-y-2.5 text-sm text-[rgba(250,246,236,0.82)]">
        <li><a href="/about" class="link-underline hover:text-[var(--color-gold)]">About Us</a></li>
        <li><a href="/upsc" class="link-underline hover:text-[var(--color-gold)]">About UPSC</a></li>
        <li><a href="/focus-school" class="link-underline hover:text-[var(--color-gold)]">Focus School</a></li>
        <li><a href="/directors-message" class="link-underline hover:text-[var(--color-gold)]">Director's Message</a></li>
        <li><a href="/messages" class="link-underline hover:text-[var(--color-gold)]">Civil Servants</a></li>
        <li><a href="/gallery" class="link-underline hover:text-[var(--color-gold)]">Gallery</a></li>
      </ul>
    </div>

    <div>
      <h4 class="text-sm tracking-[0.22em] uppercase text-[var(--color-gold)] font-sans font-semibold">Contact</h4>
      <address class="mt-5 not-italic text-sm leading-relaxed text-[rgba(250,246,236,0.82)] space-y-4">
        <div>
          <span class="block text-[11px] uppercase tracking-widest text-[rgba(250,246,236,0.5)]">Mode</span>
          100% Online · PAN India
        </div>
        <div>
          <span class="block text-[11px] uppercase tracking-widest text-[rgba(250,246,236,0.5)]">Call / WhatsApp</span>
          <a href="tel:+918329544987" class="link-underline hover:text-[var(--color-gold)]">+91 83295 44987</a>
        </div>
        <div>
          <span class="block text-[11px] uppercase tracking-widest text-[rgba(250,246,236,0.5)]">Email</span>
          <a href="mailto:knowledge4ias@gmail.com" class="link-underline hover:text-[var(--color-gold)]">knowledge4ias@gmail.com</a>
        </div>
      </address>
    </div>
  </div>

  <div class="relative border-t border-white/10">
    <div class="max-w-7xl mx-auto px-5 sm:px-8 py-6 flex flex-col md:flex-row md:items-center md:justify-between gap-3 text-xs text-[rgba(250,246,236,0.55)]">
      <p>© {year} Knowledge IAS Academy. All rights reserved.</p>
      <p>Director &amp; Founder — Mr. Ajay Sah</p>
      <p>Website created by <a href="https://webaccuracy.com" target="_blank" rel="noopener noreferrer" class="text-[var(--color-gold)] link-underline">webaccuracy.com</a></p>
    </div>
  </div>
</footer>
