---
const { pathname } = Astro.url;
type NavLink = { href: string; label: string };
type NavGroup = { label: string; children: NavLink[] };
type NavItem = NavLink | NavGroup;

const navItems: NavItem[] = [
  { href: "/", label: "Home" },
  {
    label: "About",
    children: [
      { href: "/about", label: "About Us" },
      { href: "/upsc", label: "About UPSC" },
    ],
  },
  { href: "/focus-school", label: "Focus School" },
  { href: "/directors-message", label: "Director's Message" },
  { href: "/messages", label: "Civil Servants" },
  { href: "/gallery", label: "Gallery" },
  { href: "/contact", label: "Contact" },
];

const isActive = (href: string) => (href === "/" ? pathname === "/" : pathname.startsWith(href));
const isGroup = (item: NavItem): item is NavGroup => "children" in item;
const isGroupActive = (group: NavGroup) => group.children.some((c) => isActive(c.href));
---

<header
  data-navbar
  class="sticky top-0 z-40 backdrop-blur-md bg-[rgba(250,246,236,0.82)] border-b border-transparent transition-[background,border-color,box-shadow] duration-300 data-[scrolled=true]:bg-[rgba(250,246,236,0.95)] data-[scrolled=true]:border-[var(--color-line)] data-[scrolled=true]:shadow-[0_6px_24px_-18px_rgba(11,11,11,0.25)]"
>
  <div class="max-w-7xl mx-auto px-5 sm:px-8 h-20 sm:h-24 flex items-center justify-between">
    <a href="/" class="flex items-center gap-3 -my-2 group" aria-label="Knowledge IAS home">
      <img src="/logo.png" alt="Knowledge IAS" class="h-14 sm:h-16 w-auto object-contain transition-transform duration-300 group-hover:scale-[1.03]" />
      <span class="sr-only">Knowledge IAS</span>
    </a>

    <nav class="hidden lg:flex items-center gap-1" aria-label="Primary">
      {navItems.map((item) => (
        isGroup(item) ? (
          <div class="relative group">
            <button
              type="button"
              aria-haspopup="true"
              class={`relative px-3 py-2 text-sm font-medium rounded-full transition-colors inline-flex items-center gap-1 cursor-default ${
                isGroupActive(item)
                  ? "text-[var(--color-ink)]"
                  : "text-[var(--color-ink-soft)] hover:text-[var(--color-ink)] hover:bg-[rgba(245,166,35,0.12)]"
              }`}
            >
              {item.label}
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-200 group-hover:rotate-180 group-focus-within:rotate-180">
                <polyline points="6 9 12 15 18 9"/>
              </svg>
              {isGroupActive(item) && (
                <span class="absolute left-1/2 -translate-x-1/2 -bottom-0.5 h-[3px] w-5 rounded-full bg-[var(--color-gold)]"></span>
              )}
            </button>
            <div class="absolute left-1/2 -translate-x-1/2 top-full pt-2 invisible opacity-0 translate-y-1 group-hover:visible group-hover:opacity-100 group-hover:translate-y-0 group-focus-within:visible group-focus-within:opacity-100 group-focus-within:translate-y-0 transition-all duration-200 z-50">
              <div class="bg-[var(--color-cream)] border border-[var(--color-line)] rounded-xl shadow-[0_16px_40px_-16px_rgba(11,11,11,0.22)] py-2 min-w-[180px]">
                {item.children.map((c) => (
                  <a
                    href={c.href}
                    class={`block px-4 py-2 text-sm transition-colors ${
                      isActive(c.href)
                        ? "text-[var(--color-ink)] bg-[var(--color-gold-soft)]"
                        : "text-[var(--color-ink-soft)] hover:text-[var(--color-ink)] hover:bg-[var(--color-gold-soft)]/60"
                    }`}
                  >
                    {c.label}
                  </a>
                ))}
              </div>
            </div>
          </div>
        ) : (
          <a
            href={item.href}
            class={`relative px-3 py-2 text-sm font-medium rounded-full transition-colors ${
              isActive(item.href)
                ? "text-[var(--color-ink)]"
                : "text-[var(--color-ink-soft)] hover:text-[var(--color-ink)] hover:bg-[rgba(245,166,35,0.12)]"
            }`}
          >
            {item.label}
            {isActive(item.href) && (
              <span class="absolute left-1/2 -translate-x-1/2 -bottom-0.5 h-[3px] w-5 rounded-full bg-[var(--color-gold)]"></span>
            )}
          </a>
        )
      ))}
    </nav>

    <div class="hidden lg:flex items-center gap-3">
      <a href="/contact" class="btn-primary text-sm !py-2 !px-4">Enroll Now</a>
    </div>

    <button
      id="menu-toggle"
      class="lg:hidden p-2 rounded-full hover:bg-[var(--color-gold-soft)] transition-colors"
      aria-label="Toggle navigation"
      aria-expanded="false"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="7" x2="20" y2="7"></line><line x1="4" y1="12" x2="20" y2="12"></line><line x1="4" y1="17" x2="20" y2="17"></line></svg>
    </button>
  </div>

  <div id="mobile-menu" class="lg:hidden hidden border-t border-[var(--color-line)] bg-[var(--color-cream)]">
    <nav class="px-5 py-4 flex flex-col gap-1" aria-label="Mobile primary">
      {navItems.map((item) => (
        isGroup(item) ? (
          <>
            <p class="px-3 pt-3 pb-1 text-[10px] uppercase tracking-[0.18em] text-[var(--color-muted)] font-semibold">{item.label}</p>
            {item.children.map((c) => (
              <a
                href={c.href}
                class={`px-5 py-2 rounded-lg text-sm font-medium ${
                  isActive(c.href) ? "bg-[var(--color-gold-soft)] text-[var(--color-ink)]" : "text-[var(--color-ink-soft)]"
                }`}
              >
                {c.label}
              </a>
            ))}
          </>
        ) : (
          <a
            href={item.href}
            class={`px-3 py-2.5 rounded-lg text-sm font-medium ${
              isActive(item.href) ? "bg-[var(--color-gold-soft)] text-[var(--color-ink)]" : "text-[var(--color-ink-soft)]"
            }`}
          >
            {item.label}
          </a>
        )
      ))}
      <a href="/contact" class="btn-primary mt-3 justify-center">Enroll Now</a>
    </nav>
  </div>
</header>

<script is:inline>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  if (toggle && menu) {
    toggle.addEventListener("click", () => {
      const open = menu.classList.toggle("hidden") === false;
      toggle.setAttribute("aria-expanded", String(open));
    });
  }
</script>
