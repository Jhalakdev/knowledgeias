# Knowledge IAS Academy — server config
# Copy to .env.local for local dev and edit. On Vercel, set these in
# Project Settings → Environment Variables.

# ----- Admin credentials for /admin -----
ADMIN_USER=admin
ADMIN_PASS=knowledgeias2026

# ----- Session cookie signing secret (REQUIRED IN PRODUCTION) -----
# Generate a strong value with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET=

# ----- Storage -----
# Local dev: leave these blank. The site will use JSON files in site/data/.
# Production (Vercel): add the "Upstash for Redis" integration from Vercel
# Marketplace — these two variables will be auto-populated on deploy.
KV_REST_API_URL=
KV_REST_API_TOKEN=
