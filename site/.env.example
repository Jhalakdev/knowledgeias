# Knowledge IAS Academy — server config
# Copy to .env for local dev and change the values before deploying.

# Admin credentials for /admin
ADMIN_USER=admin
ADMIN_PASS=knowledgeias2026

# Secret used to sign session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET=

# Path to the submissions JSON store (optional; defaults to ./data/submissions.json)
# DB_PATH=./data/submissions.json
