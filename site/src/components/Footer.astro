---
const year = new Date().getFullYear();
---
<footer class="mt-28 bg-[var(--color-ink)] text-[var(--color-cream)]">
  <div class="max-w-7xl mx-auto px-5 sm:px-8 py-16 grid gap-12 md:grid-cols-4">
    <div class="md:col-span-2 max-w-md">
      <div class="flex items-center gap-3">
        <img src="/logo.png" alt="Knowledge IAS" class="h-20 w-auto object-contain" style="filter: brightness(0) invert(1);" />
      </div>
      <p class="mt-4 text-sm leading-relaxed text-[rgba(250,246,236,0.72)]">
        A premier academy guiding aspirants of the UPSC Civil Services Examination. Home to <span class="text-[var(--color-gold)]">FOCUS&nbsp;SCHOOL</span> — our flagship programme for school students aspiring to serve the nation.
      </p>
    </div>

    <div>
      <h4 class="text-sm tracking-[0.2em] uppercase text-[var(--color-gold)] font-sans font-semibold">Explore</h4>
      <ul class="mt-4 space-y-2 text-sm text-[rgba(250,246,236,0.82)]">
        <li><a href="/about" class="hover:text-[var(--color-gold)]">About Us</a></li>
        <li><a href="/upsc" class="hover:text-[var(--color-gold)]">About UPSC</a></li>
        <li><a href="/focus-school" class="hover:text-[var(--color-gold)]">Focus School</a></li>
        <li><a href="/directors-message" class="hover:text-[var(--color-gold)]">Director's Message</a></li>
        <li><a href="/messages" class="hover:text-[var(--color-gold)]">Civil Servants</a></li>
        <li><a href="/gallery" class="hover:text-[var(--color-gold)]">Gallery</a></li>
      </ul>
    </div>

    <div>
      <h4 class="text-sm tracking-[0.2em] uppercase text-[var(--color-gold)] font-sans font-semibold">Contact</h4>
      <address class="mt-4 not-italic text-sm leading-relaxed text-[rgba(250,246,236,0.82)]">
        Knowledge IAS Academy<br />
        2nd Floor, 21-B, Old Rajinder Nagar<br />
        New Delhi — 110060, India<br /><br />
        <a href="tel:+911141234567" class="hover:text-[var(--color-gold)]">+91 11 4123 4567</a><br />
        <a href="mailto:info@knowledgeias.in" class="hover:text-[var(--color-gold)]">info@knowledgeias.in</a>
      </address>
    </div>
  </div>

  <div class="border-t border-white/10">
    <div class="max-w-7xl mx-auto px-5 sm:px-8 py-6 flex flex-col md:flex-row md:items-center md:justify-between gap-3 text-xs text-[rgba(250,246,236,0.55)]">
      <p>© {year} Knowledge IAS Academy. All rights reserved.</p>
      <p>Director &amp; Founder — Mr. Ajay Sah</p>
      <p>Website created by <a href="https://webaccuracy.com" target="_blank" rel="noopener noreferrer" class="text-[var(--color-gold)] hover:underline">webaccuracy.com</a></p>
    </div>
  </div>
</footer>
