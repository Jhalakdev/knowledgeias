---
import Layout from "../layouts/Layout.astro";

const stats = [
  { value: "10+", label: "Years of UPSC Mentorship" },
  { value: "900+", label: "Annual CSE Selections (PAN India)" },
  { value: "IIT · NIT · BHU", label: "Seminars & Webinars Delivered" },
];

const pillars = [
  {
    tag: "Our Flagship",
    title: "FOCUS SCHOOL",
    body: "A specialised course for school-going students dreaming of a Civil Services career — built to lay a decade-long foundation before the exam even begins.",
    href: "/focus-school",
  },
  {
    tag: "Mentor-Led",
    title: "Director's Message",
    body: "A personal note from Mr. Ajay Sah — Director and Founder — on why starting early matters, and how we shape aspirants, not just students.",
    href: "/directors-message",
  },
  {
    tag: "Know the Exam",
    title: "About UPSC",
    body: "A complete primer on the Civil Services Examination — posts under UPSC, stage-wise pattern, marking scheme and frequently asked questions.",
    href: "/upsc",
  },
];
---

<Layout>
  <!-- HERO -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 -z-10">
      <div class="absolute top-0 right-0 w-[55%] h-[90%] bg-[radial-gradient(ellipse_at_top_right,rgba(245,166,35,0.18),transparent_70%)]"></div>
      <div class="absolute bottom-0 left-0 w-[50%] h-[60%] bg-[radial-gradient(ellipse_at_bottom_left,rgba(245,166,35,0.08),transparent_70%)]"></div>
    </div>

    <div class="max-w-7xl mx-auto px-5 sm:px-8 pt-16 pb-20 lg:pt-24 lg:pb-32 grid lg:grid-cols-12 gap-12 items-center">
      <div class="lg:col-span-7">
        <span class="chip">Premier UPSC Academy · New Delhi</span>
        <h1 class="mt-6 text-4xl sm:text-5xl lg:text-6xl leading-[1.05] font-serif">
          Where <span class="gold-underline">future civil servants</span> begin their story.
        </h1>
        <p class="mt-6 text-lg text-[var(--color-muted)] leading-relaxed max-w-xl">
          Knowledge IAS Academy is a premier coaching institute preparing aspirants for the UPSC Civil Services Examination — with structured mentorship, a decade of faculty experience, and our flagship programme built exclusively for school students.
        </p>
        <div class="mt-8 flex flex-wrap items-center gap-3">
          <a href="/focus-school" class="btn-primary">
            Explore FOCUS SCHOOL
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </a>
          <a href="/contact" class="btn-ghost">Book a Counselling Call</a>
        </div>

        <dl class="mt-14 grid grid-cols-3 gap-6 max-w-xl">
          {stats.map((s) => (
            <div>
              <dt class="text-2xl sm:text-3xl font-serif text-[var(--color-ink)]">{s.value}</dt>
              <dd class="mt-1 text-xs uppercase tracking-wider text-[var(--color-muted)]">{s.label}</dd>
            </div>
          ))}
        </dl>
      </div>

      <div class="lg:col-span-5 relative">
        <div class="relative aspect-[4/5] rounded-[2rem] overflow-hidden card">
          <img
            src="https://images.unsplash.com/photo-1523050854058-8df90110c9f1?auto=format&fit=crop&w=1000&q=70"
            alt="Students preparing for UPSC"
            loading="eager"
            class="absolute inset-0 w-full h-full object-cover"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-black/10 to-transparent"></div>
          <div class="absolute bottom-6 left-6 right-6 text-white">
            <p class="text-xs uppercase tracking-[0.25em] text-[var(--color-gold)]">Flagship Programme</p>
            <p class="mt-1 font-serif text-2xl">Built for tomorrow's administrators.</p>
          </div>
        </div>

        <div class="absolute -left-4 -bottom-6 w-56 card p-5 hidden md:block">
          <p class="text-[11px] uppercase tracking-[0.22em] text-[var(--color-gold-deep)] font-semibold">Director</p>
          <p class="mt-2 font-serif text-lg leading-tight">Mr. Ajay Sah</p>
          <p class="mt-1 text-xs text-[var(--color-muted)] leading-relaxed">
            A decade of teaching across GS Score, Next IAS, Chanakya, Target UPSC and more.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- PILLARS -->
  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-5 sm:px-8">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6">
        <div class="max-w-xl">
          <p class="text-xs uppercase tracking-[0.22em] text-[var(--color-gold-deep)] font-semibold">What we offer</p>
          <h2 class="mt-3 text-3xl sm:text-4xl">A structured path to the Civil Services.</h2>
        </div>
        <p class="max-w-md text-[var(--color-muted)]">
          Everything at Knowledge IAS revolves around one idea — start early, build deeply, and leave nothing to chance.
        </p>
      </div>

      <div class="mt-12 grid md:grid-cols-3 gap-6">
        {pillars.map((p) => (
          <a href={p.href} class="card p-7 group transition-transform hover:-translate-y-1">
            <span class="chip">{p.tag}</span>
            <h3 class="mt-5 text-2xl">{p.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-[var(--color-muted)]">{p.body}</p>
            <span class="mt-6 inline-flex items-center gap-2 text-sm font-medium text-[var(--color-ink)] group-hover:text-[var(--color-gold-deep)]">
              Learn more
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FOCUS SCHOOL HIGHLIGHT -->
  <section class="relative py-20 lg:py-28 bg-[var(--color-ink)] text-[var(--color-cream)] overflow-hidden">
    <div class="absolute inset-0 -z-0 opacity-[0.07]" style="background-image: radial-gradient(circle at 20% 30%, #f5a623 0, transparent 40%), radial-gradient(circle at 80% 70%, #f5a623 0, transparent 40%);"></div>

    <div class="relative max-w-7xl mx-auto px-5 sm:px-8 grid lg:grid-cols-12 gap-12 items-center">
      <div class="lg:col-span-7">
        <span class="chip !bg-[var(--color-gold)] !text-[var(--color-ink)]">Spotlight · Flagship Programme</span>
        <h2 class="mt-6 text-4xl sm:text-5xl leading-tight font-serif text-[var(--color-cream)]">
          FOCUS <span class="text-[var(--color-gold)]">SCHOOL</span><br />
          A head start, by design.
        </h2>
        <p class="mt-6 text-[rgba(250,246,236,0.78)] text-lg leading-relaxed max-w-2xl">
          Our most ambitious course — crafted for school students who aspire to clear the UPSC. Built around 70+ guided lectures across Internal Security, Indian Society, Ethics, Science &amp; Technology, International Relations and Post-Independence History.
        </p>

        <div class="mt-8 grid grid-cols-2 md:grid-cols-4 gap-4">
          {[
            { k: "70+", v: "Live Lectures" },
            { k: "6", v: "Core Subjects" },
            { k: "1:1", v: "Mentor Access" },
            { k: "PAN-India", v: "Aspirants" },
          ].map((i) => (
            <div class="border-l-2 border-[var(--color-gold)] pl-4">
              <div class="font-serif text-2xl">{i.k}</div>
              <div class="text-xs uppercase tracking-widest text-[rgba(250,246,236,0.65)] mt-1">{i.v}</div>
            </div>
          ))}
        </div>

        <div class="mt-10 flex flex-wrap gap-3">
          <a href="/focus-school" class="btn-primary !bg-[var(--color-gold)] !text-[var(--color-ink)] hover:!bg-[var(--color-cream)]">
            See the full curriculum
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </a>
          <a href="/contact" class="btn-ghost !border-[var(--color-cream)] !text-[var(--color-cream)] hover:!bg-[var(--color-cream)] hover:!text-[var(--color-ink)]">Enrol your child</a>
        </div>
      </div>

      <div class="lg:col-span-5">
        <div class="card !bg-[rgba(255,255,255,0.04)] !border-white/10 p-8 backdrop-blur-sm">
          <p class="text-xs uppercase tracking-[0.25em] text-[var(--color-gold)] font-semibold">What students learn</p>
          <ul class="mt-6 space-y-4 text-sm text-[rgba(250,246,236,0.82)]">
            {[
              "Internal Security — terrorism, cyber security, border management",
              "Indian Society — caste, communalism, urbanization, Census 2011",
              "Ethics — schools of thought, Indian & Western thinkers, integrity",
              "Science & Tech — space, biotech, defence, IPR",
              "International Relations — QUAD, BRICS, neighbourhood policy",
              "Post-Independence History — from Nehru era to 21st century",
            ].map((x) => (
              <li class="flex gap-3">
                <span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-[var(--color-gold)] flex-none"></span>
                <span>{x}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- TESTIMONIAL TEASER -->
  <section class="py-20 lg:py-28">
    <div class="max-w-5xl mx-auto px-5 sm:px-8 text-center">
      <p class="text-xs uppercase tracking-[0.22em] text-[var(--color-gold-deep)] font-semibold">Messages from Civil Servants</p>
      <blockquote class="mt-6 text-2xl sm:text-3xl font-serif leading-snug text-[var(--color-ink)]">
        “Starting preparation during school years gives you a decade of quiet, compounding advantage. It's the single highest-leverage decision an aspirant can make.”
      </blockquote>
      <p class="mt-6 text-sm tracking-wider uppercase text-[var(--color-muted)]">— A serving IAS Officer, Batch of 2019</p>
      <a href="/messages" class="mt-10 inline-flex btn-ghost">Read all messages</a>
    </div>
  </section>

  <!-- CTA -->
  <section class="pb-24">
    <div class="max-w-7xl mx-auto px-5 sm:px-8">
      <div class="card p-10 md:p-14 bg-gradient-to-br from-[var(--color-cream-deep)] to-[var(--color-gold-soft)] border-[var(--color-gold-deep)]/20 grid md:grid-cols-[1.2fr_1fr] gap-8 items-center">
        <div>
          <h2 class="text-3xl sm:text-4xl">Ready to visit us?</h2>
          <p class="mt-4 text-[var(--color-ink-soft)] leading-relaxed max-w-lg">
            Walk into our academy in New Delhi for a no-obligation counselling session. We'll help you map out your UPSC journey — whether you're starting in Class IX or already in your graduation years.
          </p>
        </div>
        <div class="flex flex-wrap md:justify-end gap-3">
          <a href="/contact" class="btn-primary">Book a Visit</a>
          <a href="tel:+911141234567" class="btn-ghost">Call +91 11 4123 4567</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
