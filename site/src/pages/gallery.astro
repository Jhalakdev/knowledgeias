---
import Layout from "../layouts/Layout.astro";

// Real-feeling placeholders via Unsplash source URLs. Swap with your own photos later.
const shots = [
  { caption: "Classroom session — FOCUS SCHOOL batch", ratio: "md:row-span-2 md:col-span-2", u: "https://images.unsplash.com/photo-1523240795612-9a054b0db644?auto=format&fit=crop&w=1200&q=72" },
  { caption: "Seminar at IIT Delhi", ratio: "md:col-span-1", u: "https://images.unsplash.com/photo-1427504494785-3a9ca7044f45?auto=format&fit=crop&w=900&q=72" },
  { caption: "Library &amp; reading lounge", ratio: "md:col-span-1", u: "https://images.unsplash.com/photo-1521587760476-6c12a4b040da?auto=format&fit=crop&w=900&q=72" },
  { caption: "Guest lecture — serving IAS officer", ratio: "md:col-span-2", u: "https://images.unsplash.com/photo-1515168833906-d2a3b82b302a?auto=format&fit=crop&w=1200&q=72" },
  { caption: "Mains answer-writing workshop", ratio: "md:col-span-1", u: "https://images.unsplash.com/photo-1456406644174-8ddd4cd52a06?auto=format&fit=crop&w=900&q=72" },
  { caption: "Annual orientation day", ratio: "md:col-span-1", u: "https://images.unsplash.com/photo-1577896851231-70ef18881754?auto=format&fit=crop&w=900&q=72" },
  { caption: "Weekly prelims test series", ratio: "md:col-span-2", u: "https://images.unsplash.com/photo-1606326608606-aa0b62935f2b?auto=format&fit=crop&w=1200&q=72" },
  { caption: "Campus at Old Rajinder Nagar", ratio: "md:col-span-1", u: "https://images.unsplash.com/photo-1498243691581-b145c3f54a5a?auto=format&fit=crop&w=900&q=72" },
  { caption: "Director's interaction hour", ratio: "md:col-span-1", u: "https://images.unsplash.com/photo-1544531585-9847b68c8c86?auto=format&fit=crop&w=900&q=72" },
];
---
<Layout title="Gallery — Knowledge IAS Academy">
  <section class="max-w-7xl mx-auto px-5 sm:px-8 pt-16 lg:pt-24 pb-14">
    <div data-reveal>
      <span class="chip"><span class="dot"></span>Gallery</span>
      <h1 class="mt-6 text-4xl sm:text-5xl lg:text-6xl leading-tight">
        Moments from <span class="gold-underline-animated">our classrooms</span>.
      </h1>
      <p class="mt-6 text-lg text-[var(--color-muted)] max-w-3xl leading-relaxed">
        A glimpse of life at Knowledge IAS — classrooms, workshops, seminars and the little moments that make an aspirant's journey.
      </p>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-5 sm:px-8 pb-24">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-5 auto-rows-[190px] md:auto-rows-[220px]">
      {shots.map((p, i) => (
        <figure
          data-reveal
          data-reveal-delay={String((i % 5) + 1)}
          class={`${p.ratio} relative overflow-hidden rounded-2xl card !p-0 group cursor-zoom-in`}
        >
          <img
            src={p.u}
            alt={p.caption}
            loading="lazy"
            decoding="async"
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-[900ms] ease-out group-hover:scale-[1.06]"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/75 via-black/20 to-transparent opacity-90 group-hover:opacity-100 transition-opacity"></div>
          <figcaption class="absolute inset-x-0 bottom-0 p-4 text-xs tracking-wide text-white">
            <span class="text-[var(--color-gold)] font-semibold">0{i + 1}</span>
            <span class="mx-2 opacity-50">·</span>
            <span set:html={p.caption}></span>
          </figcaption>
          <div class="absolute top-3 right-3 h-8 w-8 rounded-full bg-white/20 backdrop-blur-md flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 3 21 3 21 9"/><polyline points="9 21 3 21 3 15"/><line x1="21" y1="3" x2="14" y2="10"/><line x1="3" y1="21" x2="10" y2="14"/></svg>
          </div>
        </figure>
      ))}
    </div>

    <p class="mt-10 text-center text-sm text-[var(--color-muted)]">Placeholder images. Share your academy photographs at <a class="link-underline hover:text-[var(--color-gold-deep)]" href="mailto:info@knowledgeias.in">info@knowledgeias.in</a> and we'll feature them here.</p>
  </section>
</Layout>
