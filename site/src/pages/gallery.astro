---
import Layout from "../layouts/Layout.astro";

const placeholders = [
  { caption: "Classroom session — FOCUS SCHOOL batch", ratio: "aspect-[4/5]" },
  { caption: "Seminar at IIT Delhi", ratio: "aspect-square" },
  { caption: "Library & reading lounge", ratio: "aspect-[4/5]" },
  { caption: "Guest lecture — serving IAS officer", ratio: "aspect-square" },
  { caption: "Mains answer-writing workshop", ratio: "aspect-[4/5]" },
  { caption: "Annual orientation day", ratio: "aspect-square" },
  { caption: "Weekly prelims test series", ratio: "aspect-[4/5]" },
  { caption: "Campus at Old Rajinder Nagar", ratio: "aspect-square" },
  { caption: "Director's interaction hour", ratio: "aspect-[4/5]" },
];
---
<Layout title="Gallery — Knowledge IAS Academy">
  <section class="max-w-7xl mx-auto px-5 sm:px-8 pt-16 lg:pt-24 pb-12">
    <span class="chip">Gallery</span>
    <h1 class="mt-6 text-4xl sm:text-5xl lg:text-6xl leading-tight">
      Moments from <span class="gold-underline">our classrooms</span>.
    </h1>
    <p class="mt-6 text-lg text-[var(--color-muted)] max-w-3xl leading-relaxed">
      A glimpse of life at Knowledge IAS — classrooms, workshops, seminars and the little moments that make an aspirant's journey.
    </p>
  </section>

  <section class="max-w-7xl mx-auto px-5 sm:px-8 pb-24">
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4 md:gap-5 [grid-auto-flow:dense]">
      {placeholders.map((p, i) => (
        <figure class={`${p.ratio} relative overflow-hidden rounded-2xl card !p-0 group`}>
          <div
            class="absolute inset-0 bg-gradient-to-br from-[var(--color-cream-deep)] via-[var(--color-gold-soft)] to-[var(--color-cream-deep)] flex items-center justify-center"
          >
            <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="#d98e12" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" opacity="0.6">
              <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
              <circle cx="8.5" cy="8.5" r="1.5"></circle>
              <polyline points="21 15 16 10 5 21"></polyline>
            </svg>
          </div>
          <figcaption class="absolute inset-x-0 bottom-0 p-4 bg-gradient-to-t from-black/70 via-black/20 to-transparent text-xs tracking-wide text-white">
            <span class="opacity-70">0{i + 1} · </span>{p.caption}
          </figcaption>
        </figure>
      ))}
    </div>

    <p class="mt-10 text-center text-sm text-[var(--color-muted)]">Photographs will be updated soon. Share your academy photographs at <a class="underline underline-offset-2 hover:text-[var(--color-gold-deep)]" href="mailto:info@knowledgeias.in">info@knowledgeias.in</a>.</p>
  </section>
</Layout>
